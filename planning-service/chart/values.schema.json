{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "planning chart values",
  "type": "object",
  "required": [
    "image",
    "service",
    "replicaCount"
  ],
  "properties": {
    "image": {
      "type": "object",
      "required": [
        "repository"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 50
    },
    "service": {
      "type": "object",
      "required": [
        "port",
        "targetPort"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "ingress": {
      "type": "object"
    },
    "env": {
      "type": "object",
      "properties": {
        "LOG_LEVEL": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        }
      }
    },
    "resources": {
      "type": "object"
    },
    "podSecurityContext": {
      "type": "object"
    },
    "containerSecurityContext": {
      "type": "object"
    },
    "probes": {
      "type": "object"
    },
    "pdb": {
      "type": "object"
    },
    "config": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "greeting": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "string",
          "enum": [
            "dev",
            "preview",
            "staging",
            "prod"
          ]
        }
      }
    },
    "migration": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 300
        },
        "backoffLimit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "fail": {
          "type": "boolean"
        }
      }
    }
  }
}
